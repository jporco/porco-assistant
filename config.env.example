# Workspace opened by Cursor (default: home directory)
ASSISTANT_WORKSPACE=${HOME}

# Cursor agent model (see Cursor CLI docs)
ASSISTANT_MODEL=composer-2.5

# UI automation
ASSISTANT_FOCUS_CURSOR=0
ASSISTANT_OPEN_CURSOR_BG=1

# Microphone: substring of device name or numeric index (aplay -l / arecord -l)
MIC_DEVICE=default
MIC_VOLUME=120%

# Speech-to-text (faster-whisper)
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
WHISPER_BEAM=5
WHISPER_VAD=1
STT_RMS=4
STT_GAIN=2.5
STT_SILENCE_S=0.45
STT_MAX_S=8
PTT_ESPERA_S=4

# Text-to-speech (Piper pt-BR cadu)
PIPER_BIN=@INSTALL_DIR@/bin/piper
PIPER_MODEL=@INSTALL_DIR@/models/pt-BR-cadu-medium.onnx
PIPER_RATE=22050
PIPER_SPEED=1.6
PIPER_PITCH=0.88
PIPER_VOLUME=1.0
PIPER_PLAYER=aplay
AGENT_TTS_MAX_CHARS=600
